#!/bin/bash

# Oclaude - Claude Code Ollama Launcher
# Starts Claude Code using local Ollama models

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LAST_MODEL_FILE="$HOME/.oclaude-last-model"

# Colors for output (bash $'...' expands escapes at assignment time—no printf %b needed)
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
NC=$'\033[0m' # No Color

# Print a line with ANSI color variables. Uses printf %s to avoid interpreting
# backslash escapes in the arguments (safe for user-supplied data).
print_line() {
	printf '%s\n' "$*"
}

print_error() {
	printf '%s\n' "${RED}${*}${NC}" >&2
}

print_warn() {
	printf '%s\n' "${YELLOW}${*}${NC}" >&2
}

print_success() {
	printf '%s\n' "${GREEN}${*}${NC}"
}

print_info() {
	printf '%s\n' "${BLUE}${*}${NC}"
}

show_help() {
	print_info "Oclaude - Claude Code Ollama Launcher"
	printf '\n'
	printf '%s\n' "Starts Claude Code using local Ollama models."
	printf '\n'
	print_warn "USAGE:"
	printf '%s\n' "    $0 [OPTIONS]"
	printf '\n'
	print_warn "OPTIONS:"
	printf '%s\n' "    -h, --help              Show this help message"
	printf '%s\n' "    -s, --select            Force model selection prompt"
	printf '%s\n' "    -m, --model MODELNAME   Use the specified model directly"
	printf '%s\n' "    -r, --reset             Forget the saved last-model preference"
	printf '%s\n' "    -t, --test              Test Ollama server and Claude Code and exit"
	printf '\n'
	print_warn "REQUIREMENTS:"
	printf '%s\n' "    - Ollama installed and running"
	printf '%s\n' "    - Claude Code CLI installed"
	printf '%s\n' "    - At least one model pulled (e.g., ollama pull llama3.2)"
	printf '\n'
	print_warn "EXAMPLES:"
	printf '%s\n' "    $0                              # Use last model or prompt"
	printf '%s\n' "    $0 -s                           # Force model selection"
	printf '%s\n' "    $0 -m llama3.2                  # Use specific model"
	printf '%s\n' "    $0 -m codellama:7b              # Use specific model with tag"
	printf '%s\n' "    $0 -t                           # Test Ollama server connection"
	printf '%s\n' "    $0 -r                           # Forget saved model preference"
}

# Escape regex metacharacters so the model name is treated as a literal string.
escape_regex() {
	sed 's/[.[\*^$()+?{|]/\\&/g' <<< "$1"
}

# Test Ollama server connection
test_ollama() {
	print_info "Testing Ollama server connection..."

	# Check if ollama command exists
	if ! command -v ollama &> /dev/null; then
		print_error "✗ ollama command not found"
		print_warn "Install Ollama: https://ollama.com"
		return 1
	fi
	print_success "✓ ollama command found"

	# Check if server is running
	if ! ollama ls &> /dev/null; then
		print_error "✗ Ollama server is not running"
		print_warn "Start server: ollama serve"
		return 1
	fi
	print_success "✓ Ollama server is running"

	# Check if we can list models
	local model_count
	model_count=$(get_available_models | wc -l)
	if [[ "$model_count" -eq 0 ]]; then
		print_warn "! Ollama server working, but no models installed"
		print_warn "Pull a model: ollama pull <model>"
	else
		print_success "✓ Found $model_count model(s) available"
	fi

	# Quick connectivity test with a simple request
	local response
	response=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:11434/api/tags 2>/dev/null)
	if [[ "$response" == "200" ]]; then
		print_success "✓ API endpoint responding (HTTP $response)"
	else
		print_warn "! API endpoint not responding (HTTP $response)"
	fi

	printf '\n'
	print_info "Checking Claude Code..."
	if ! command -v claude &> /dev/null; then
		print_error "✗ claude command not found"
		print_warn "Install Claude Code: https://docs.anthropic.com/en/docs/claude-code"
		printf '\n'
		print_warn "Ollama server is healthy, but Claude Code is not installed!"
		return 1
	fi
	print_success "✓ claude command found"

	printf '\n'
	print_success "Ollama server and Claude Code are both ready!"
	return 0
}

# Get available models
get_available_models() {
	ollama ls 2>/dev/null | tail -n +2 | awk '{print $1}'
}

# Check if a model is available.
# The model name is escaped before being used in a regex to prevent
# command injection via $(...) or backticks in model names.
is_model_available() {
	local model="$1"
	local escaped available
	escaped=$(escape_regex "$model")
	available=$(get_available_models)

	# Check exact match or prefix match (for model:tag format)
	printf '%s' "$available" | grep -qE "^${escaped}(:|$)"
}

# Select model from available list
select_model() {
	local models=()
	local i=1

	print_info "Available Ollama models:"

	while IFS= read -r model; do
		if [[ -n "$model" ]]; then
			models+=("$model")
			printf '%s\n' "  ${GREEN}$i)${NC} $model" >&2
			i=$((i + 1))
		fi
	done < <(get_available_models)

	if [[ ${#models[@]} -eq 0 ]]; then
		print_error "No models available. Pull a model first with: ollama pull <model>"
		exit 1
	fi

	printf '\n' >&2

	local choice
	while true; do
		read -r -p "Select a model (1-${#models[@]}): " choice

		if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le "${#models[@]}" ]]; then
			printf '%s' "${models[$((choice-1))]}"
			return 0
		else
			print_warn "Invalid selection. Please enter a number between 1 and ${#models[@]}."
		fi
	done
}

# Save model name to the last-model file for reuse on next launch.
# Uses printf (not echo) and locks permissions down to user-only.
save_last_model() {
	local model="$1"
	printf '%s\n' "$model" > "$LAST_MODEL_FILE"
	chmod 600 "$LAST_MODEL_FILE" 2>/dev/null || true
}

# Launch Claude Code via ollama with the given model.
launch_claude() {
	local model="$1"
	ollama launch claude --model "$model"
}

# Reset saved model preference
reset_config() {
	if [[ -f "$LAST_MODEL_FILE" ]]; then
		rm -f "$LAST_MODEL_FILE"
		print_success "✓ Saved model preference cleared"
	else
		print_warn "! No saved model preference to clear"
	fi
}

# Main logic
main() {
	local force_select=false
	local specified_model=""

	# Parse arguments
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--help|-h)
				show_help
				exit 0
				;;
			--select|-s)
				force_select=true
				shift
				;;
			--model|-m)
				if [[ -z "${2:-}" ]]; then
					print_error "Error: --model requires a model name argument"
					exit 1
				fi
				specified_model="$2"
				shift 2
				;;
			--test|-t)
				test_ollama
				exit $?
				;;
			--reset|-r)
				reset_config
				exit 0
				;;
			*)
				print_error "Error: Unknown option: $1"
				print_warn "Use --help for usage information"
				exit 1
				;;
		esac
	done

	# If model specified via --model, use it directly
	if [[ -n "$specified_model" ]]; then
		if ! is_model_available "$specified_model"; then
			printf '%s\n' "${RED}Error: Model '${specified_model}' is not available${NC}" >&2
			printf '%s\n' "${YELLOW}Run 'ollama pull ${specified_model}' to download it${NC}" >&2
			exit 1
		fi
		printf '%s\n' "${GREEN}Using specified model:${NC} ${specified_model}"
		save_last_model "$specified_model"
		launch_claude "$specified_model"
		exit 0
	fi

	# If --select flag, force model selection
	if [[ "$force_select" == true ]]; then
		local selected
		selected=$(select_model)
		printf '%s\n' "${GREEN}Using selected model:${NC} ${selected}"
		save_last_model "$selected"
		launch_claude "$selected"
		exit 0
	fi

	# Try to use last model
	if [[ -f "$LAST_MODEL_FILE" ]]; then
		local last_model
		last_model=$(cat "$LAST_MODEL_FILE")

		if [[ -n "$last_model" ]] && is_model_available "$last_model"; then
			printf '%s\n' "${GREEN}Using last model:${NC} ${last_model}"
			launch_claude "$last_model"
			exit 0
		else
			printf '%s\n' "${YELLOW}Last model '${last_model}' is no longer available${NC}" >&2
		fi
	fi

	# No last model or not available - prompt user
	local selected
	selected=$(select_model)
	printf '%s\n' "${GREEN}Using selected model:${NC} ${selected}"
	save_last_model "$selected"
	launch_claude "$selected"
}

main "$@"
